# Base URL of your Penpot instance, without trailing slash
PENPOT_BASE_URL=https://design.example.com

# Optional Bearer token if your Penpot deployment uses token auth
PENPOT_TOKEN=

# Authorization scheme for PENPOT_TOKEN. Use Token for Penpot RPC by default.
PENPOT_AUTH_SCHEME=Token

# Optional request timeout in milliseconds
PENPOT_TIMEOUT_MS=20000