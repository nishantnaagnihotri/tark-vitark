# Figma Project Metadata
#
# Copy this file to .figma-config.local and replace placeholder values.
# .figma-config.local is gitignored; this example is committed as schema reference.

# Required keys
project_name: <your Figma project name>
plan_key: <your Figma plan key, e.g. team::123456>

# Optional convenience keys
team_name: <your Figma team name>
project_id: <your Figma project id>
plan_tier: <plan tier/quota, e.g. Pro full seat>

# Leave as empty strings until Gate 3 bootstrap creates/publishes the Design System library.
design_system_library_file_key: ""
design_system_library_url: ""

# Project-first policy: All Figma files must reside in the designated project.
# MCP create_new_file lands files in Drafts (API limitation).
# After MCP creates a new file, manually move it to the project before any
# further design work proceeds. No design activity on files in Drafts.
