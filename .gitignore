# Environment secrets — never commit
.env
.env.local
.env.*.local

# Local project config (private identifiers)
.figma-config.local

# Node dependencies
node_modules/

# Build output
dist/

# Runtime agent logs (generated at runtime, not source)
logs/

# VS Code extension — build/package outputs (also covered by tools/agent-status/.gitignore)
tools/agent-status/out/
tools/agent-status/*.vsix

# Python cache artifacts
__pycache__/
*.pyc

# Editor / IDE
.vscode/*
!.vscode/mcp.json

# OS artifacts
.DS_Store
Thumbs.db
